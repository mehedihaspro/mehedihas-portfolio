# Sanity CMS
# Get your project ID from https://sanity.io/manage
NEXT_PUBLIC_SANITY_PROJECT_ID=your_project_id_here
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2024-01-01

# Google Cloud TTS (for blog audio)
# Get from https://console.cloud.google.com
GOOGLE_CLOUD_TTS_API_KEY=your_api_key_here

# Kit (Newsletter - formerly ConvertKit)
# Get from https://app.kit.com/account/developer
KIT_API_KEY=your_api_key_here
KIT_FORM_ID=your_form_id_here
